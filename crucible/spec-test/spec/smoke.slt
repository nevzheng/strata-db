# Server tests covering literal SELECTs, comparison/logical expressions,
# and error paths through parse / analysis / lowering.
#
# Table DDL/DML (CREATE SCHEMA / TABLE, INSERT, CREATE OR REPLACE) lives
# in `ddl/`. The error cases below still fail — but now because their
# names are unqualified (tables need `project.dataset.table`) or the
# statement isn't supported yet (DROP), not because DDL is unplanned.

# Literal SELECTs ------------------------------------------------------

query T
SELECT 1
----
1

query T
SELECT 'hello'
----
hello

query T
SELECT true
----
t

query T
SELECT false
----
f

# Boolean expressions --------------------------------------------------

query T
SELECT 1 = 1
----
t

query T
SELECT 1 < 2 AND 2 < 3
----
t

query T
SELECT NOT (1 = 2)
----
t

# Error paths ----------------------------------------------------------

# Catalog miss — table doesn't exist.
statement error
SELECT * FROM acme.metrics.events

# Planner doesn't handle DISTINCT yet.
statement error
SELECT DISTINCT 1

# Under-qualified names resolve against the session search path
# (`strata.public`): a bare `foo` is `strata.public.foo`, so DDL/DML/queries
# all work without spelling out the project + dataset.
statement ok
CREATE TABLE foo (a INT)

statement ok
INSERT INTO foo VALUES (1)

# Queryable bare and via the `public` schema (2-part).
query T
SELECT a FROM foo
----
1

query T
SELECT a FROM public.foo
----
1

# DROP TABLE isn't supported yet.
statement error
DROP TABLE foo
