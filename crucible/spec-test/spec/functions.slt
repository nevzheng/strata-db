# Scalar built-in functions over pgwire: ABS, and the multi-argument
# GREATEST / LEAST (also spelled MAX(a, b, …) / MIN(a, b, …)).
# Single-argument MAX/MIN are aggregates and need GROUP BY — not yet.
#
# Uses its own `strata.func` schema so the file is self-contained.

# --- ABS --------------------------------------------------------------

query T
SELECT ABS(-5)
----
5

query T
SELECT ABS(-2.5)
----
2.5

query T
SELECT ABS(5)
----
5

# --- GREATEST / LEAST -------------------------------------------------

query T
SELECT GREATEST(1, 2, 3)
----
3

query T
SELECT LEAST(3, 1, 2)
----
1

# MAX / MIN with >= 2 args are the row-wise greatest / least.
query T
SELECT MAX(1, 5, 2)
----
5

query T
SELECT MIN(4, 2, 3)
----
2

# NULLs are skipped.
query T
SELECT GREATEST(1, NULL, 2)
----
2

# Mixed numeric args coerce; the float wins.
query T
SELECT GREATEST(1, 2.5)
----
2.5

# --- unsupported / error paths ----------------------------------------

# Single-argument MAX/MIN is an aggregate — not supported yet.
statement error
SELECT MAX(1)

# Unknown function.
statement error
SELECT NOPE(1)

# --- functions over table columns -------------------------------------

statement ok
CREATE SCHEMA strata.func

statement ok
CREATE TABLE strata.func.nums (id INT, v DOUBLE PRECISION)

statement ok
INSERT INTO strata.func.nums VALUES (1, -3.5), (2, 4.0), (3, -1.0)

# ABS applied per row in the projection.
query T
SELECT ABS(v) FROM strata.func.nums
----
3.5
4
1

# Row-wise MAX across two columns (id is INT, v is DOUBLE — coerced).
query T
SELECT MAX(id, v) FROM strata.func.nums
----
1
4
3

# Filter using a function in the predicate.
query T
SELECT id FROM strata.func.nums WHERE ABS(v) > 2
----
1
2

# --- rounding ---------------------------------------------------------

query T
SELECT CEIL(2.1)
----
3

query T
SELECT FLOOR(2.9)
----
2

query T
SELECT ROUND(2.4)
----
2

# CEIL of a NUMERIC stays numeric.
query T
SELECT CEIL(NUMERIC '2.1')
----
3

# --- COALESCE: first non-null -----------------------------------------

query T
SELECT COALESCE(NULL, NULL, 3, 4)
----
3

# --- string functions -------------------------------------------------

query T
SELECT UPPER('hello')
----
HELLO

query T
SELECT LOWER('HeLLo')
----
hello

query T
SELECT LENGTH('Привет 🦀')
----
8

# Wrong arity is an arity error.
statement error
SELECT REPEAT('x')

# --- NULLIF / CONCAT / SUBSTRING / TRIM -------------------------------

# NULLIF(5,5) is NULL — observed via COALESCE to avoid empty rendering.
query T
SELECT COALESCE(NULLIF(5, 5), -1)
----
-1

query T
SELECT NULLIF(5, 6)
----
5

query T
SELECT CONCAT('a', 'b', 'c')
----
abc

# CONCAT stringifies non-text args and skips NULL.
query T
SELECT CONCAT('id=', 7)
----
id=7

# || string concatenation (stringifies, like CONCAT but binary).
query T
SELECT 'a' || 'b' || 'c'
----
abc

query T
SELECT 'id=' || 7
----
id=7

query T
SELECT SUBSTRING('hello' FROM 2 FOR 3)
----
ell

query T
SELECT TRIM('  hi  ')
----
hi

query T
SELECT TRIM(LEADING 'x' FROM 'xxhi')
----
hi

# --- runtime unary minus on a column ----------------------------------

statement ok
CREATE TABLE strata.func.signed (id INT, v INT)

statement ok
INSERT INTO strata.func.signed VALUES (1, 7), (2, -3)

query T
SELECT -v FROM strata.func.signed
----
-7
3

# --- value size guard (until page-span overflow lands) ----------------

statement ok
CREATE TABLE strata.func.big (id INT, body TEXT)

# Under the cap stores fine.
statement ok
INSERT INTO strata.func.big VALUES (1, REPEAT('x', 7000))

# Over the cap is a clear error, not an opaque page failure.
statement error
INSERT INTO strata.func.big VALUES (2, REPEAT('x', 9000))

# --- CASE -------------------------------------------------------------

# Searched CASE: first true branch wins.
query T
SELECT CASE WHEN 1 > 2 THEN 'a' WHEN 2 > 1 THEN 'b' ELSE 'c' END
----
b

# Simple CASE: operand compared to each WHEN value.
query T
SELECT CASE 2 WHEN 1 THEN 'one' WHEN 2 THEN 'two' ELSE 'other' END
----
two

# No matching branch and no ELSE -> NULL (seen via COALESCE).
query T
SELECT COALESCE(CASE WHEN 1 > 2 THEN 'a' END, 'none')
----
none

# CASE over a column.
query T
SELECT CASE WHEN v < 0 THEN 'neg' ELSE 'nonneg' END FROM strata.func.signed
----
nonneg
neg
