# Scalar built-in functions over pgwire: ABS, and the multi-argument
# GREATEST / LEAST (also spelled MAX(a, b, …) / MIN(a, b, …)).
# Single-argument MAX/MIN are aggregates and need GROUP BY — not yet.
#
# Uses its own `strata.func` schema so the file is self-contained.

# --- ABS --------------------------------------------------------------

query T
SELECT ABS(-5)
----
5

query T
SELECT ABS(-2.5)
----
2.5

query T
SELECT ABS(5)
----
5

# --- GREATEST / LEAST -------------------------------------------------

query T
SELECT GREATEST(1, 2, 3)
----
3

query T
SELECT LEAST(3, 1, 2)
----
1

# MAX / MIN with >= 2 args are the row-wise greatest / least.
query T
SELECT MAX(1, 5, 2)
----
5

query T
SELECT MIN(4, 2, 3)
----
2

# NULLs are skipped.
query T
SELECT GREATEST(1, NULL, 2)
----
2

# Mixed numeric args coerce; the float wins.
query T
SELECT GREATEST(1, 2.5)
----
2.5

# --- unsupported / error paths ----------------------------------------

# Single-argument MAX/MIN is an aggregate — not supported yet.
statement error
SELECT MAX(1)

# Unknown function.
statement error
SELECT NOPE(1)

# --- functions over table columns -------------------------------------

statement ok
CREATE SCHEMA strata.func

statement ok
CREATE TABLE strata.func.nums (id INT, v DOUBLE PRECISION)

statement ok
INSERT INTO strata.func.nums VALUES (1, -3.5), (2, 4.0), (3, -1.0)

# ABS applied per row in the projection.
query T
SELECT ABS(v) FROM strata.func.nums
----
3.5
4
1

# Row-wise MAX across two columns (id is INT, v is DOUBLE — coerced).
query T
SELECT MAX(id, v) FROM strata.func.nums
----
1
4
3

# Filter using a function in the predicate.
query T
SELECT id FROM strata.func.nums WHERE ABS(v) > 2
----
1
2
