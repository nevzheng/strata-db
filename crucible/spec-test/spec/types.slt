# Scalar type coverage over pgwire. One section per logical type; the
# DATE section is the first, others (FLOAT, NUMERIC, TIMESTAMP) land here
# as they're implemented.
#
# Uses its own `strata.types` schema so the file is self-contained.

# =====================================================================
# DATE — days since the Unix epoch, rendered as YYYY-MM-DD
# =====================================================================

# --- typed literals ---------------------------------------------------

query T
SELECT DATE '2026-06-13'
----
2026-06-13

# Pre-epoch dates round-trip through the negative day count.
query T
SELECT DATE '1969-07-20'
----
1969-07-20

# --- comparisons (date vs date) ---------------------------------------

query T
SELECT DATE '2026-06-13' > DATE '2000-01-01'
----
t

query T
SELECT DATE '2000-01-01' = DATE '2000-01-01'
----
t

query T
SELECT DATE '1999-12-31' < DATE '2000-01-01'
----
t

# A DATE doesn't coerce with integers — `date < 5` is a type error.
statement error
SELECT DATE '2026-06-13' < 5

# --- calendar validation at bind time ---------------------------------

statement error
SELECT DATE '2026-13-01'

statement error
SELECT DATE '2026-06-31'

# 2023 isn't a leap year.
statement error
SELECT DATE '2023-02-29'

# --- DATE column through DDL / DML ------------------------------------

statement ok
CREATE SCHEMA strata.types

statement ok
CREATE TABLE strata.types.events (id INT, happened DATE)

statement ok
INSERT INTO strata.types.events VALUES (1, DATE '2026-06-13'), (2, DATE '1970-01-01'), (3, DATE '2000-01-01')

# Stored dates round-trip through encode/decode and render as text.
query TT
SELECT * FROM strata.types.events
----
1 2026-06-13
2 1970-01-01
3 2000-01-01

# Equality filter on a DATE column with a typed literal.
query T
SELECT id FROM strata.types.events WHERE happened = DATE '2000-01-01'
----
3

# Range filter: ids 1 (2026) and 3 (2000) qualify; id 2 (1970) does not.
# Results come back in primary-key (id) order.
query T
SELECT id FROM strata.types.events WHERE happened >= DATE '2000-01-01'
----
1
3

# Wrong type into a DATE column is rejected.
statement error
INSERT INTO strata.types.events VALUES (4, 123)

# NULL is accepted in a nullable DATE column. We confirm via the sibling
# column to avoid depending on NULL's text rendering.
statement ok
INSERT INTO strata.types.events VALUES (5, NULL)

query T
SELECT id FROM strata.types.events WHERE id = 5
----
5

# =====================================================================
# TIMESTAMP WITH TIME ZONE — absolute instant, stored/rendered as UTC
# =====================================================================

# --- typed literals (offset honored, rendered as UTC +00:00) ----------

query T
SELECT TIMESTAMP WITH TIME ZONE '2026-06-13 14:30:00+00'
----
2026-06-13 14:30:00+00:00

# A literal with no offset is interpreted as UTC.
query T
SELECT TIMESTAMPTZ '2026-06-13 14:30:00'
----
2026-06-13 14:30:00+00:00

# +02:00 normalizes to the same instant two hours earlier in UTC.
query T
SELECT TIMESTAMPTZ '2026-06-13 14:30:00+02' = TIMESTAMPTZ '2026-06-13 12:30:00+00'
----
t

query T
SELECT TIMESTAMPTZ '2026-06-13 14:30:01+00' > TIMESTAMPTZ '2026-06-13 14:30:00+00'
----
t

# Bare TIMESTAMP (WITHOUT TIME ZONE) is not modeled yet.
statement error
SELECT TIMESTAMP '2026-06-13 14:30:00'

# Invalid timestamps are rejected at bind time.
statement error
SELECT TIMESTAMPTZ '2026-13-01 00:00:00+00'

# --- TIMESTAMPTZ column through DDL / DML -----------------------------

statement ok
CREATE TABLE strata.types.logs (id INT, at TIMESTAMPTZ)

statement ok
INSERT INTO strata.types.logs VALUES (1, TIMESTAMPTZ '2026-06-13 14:30:00+02'), (2, TIMESTAMPTZ '1970-01-01 00:00:00+00')

# Stored as UTC: id 1's +02 literal comes back two hours earlier.
query TT
SELECT * FROM strata.types.logs
----
1 2026-06-13 12:30:00+00:00
2 1970-01-01 00:00:00+00:00

# Filter on a TIMESTAMPTZ column with a typed literal.
query T
SELECT id FROM strata.types.logs WHERE at = TIMESTAMPTZ '1970-01-01 00:00:00+00'
----
2

# Wrong type into a TIMESTAMPTZ column is rejected.
statement error
INSERT INTO strata.types.logs VALUES (3, 123)
