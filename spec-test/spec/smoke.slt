# Smoke specs. The server currently handles `SELECT 1` specifically and
# returns OK for everything else — the executor isn't built yet. This file
# exercises the wire path end-to-end: DDL/DML acknowledgements, a real row
# coming back from a query, and a tear-down statement.

statement ok
CREATE TABLE foo (a INT);

statement ok
INSERT INTO foo VALUES (1);

query I
SELECT 1
----
1

statement ok
DROP TABLE foo;
